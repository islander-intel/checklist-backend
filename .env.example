# ==============================================================================
# simply todo - Checklist Backend Template (.env.example)
# ==============================================================================
# Instructions: Copy to '.env' and fill in your local values.
# ==============================================================================

# Internal connection string to the todo-db vault
DATABASE_URL=postgresql://user:pass@postgres-db:5432/dbname

# Shared secret for the Router-to-Backend handshake
INTERNAL_AUTH_TOKEN=your_internal_secret_here

# Default port is 8001 for the Worker tier
PORT=8001
GIN_MODE=release
